FROM python:3.10-slim

WORKDIR /app

RUN pip install flask requests

# Crear el script proxy_transform.py directamente en el contenedor
RUN echo 'from flask import Flask, request, jsonify' > /app/proxy_transform.py && \
    echo 'import requests, json, uuid, re, os, logging' >> /app/proxy_transform.py && \
    echo 'app = Flask(__name__)' >> /app/proxy_transform.py && \
    echo 'logging.basicConfig(level=logging.INFO)' >> /app/proxy_transform.py && \
    echo 'logger = logging.getLogger(__name__)' >> /app/proxy_transform.py && \
    echo 'LITELLM_URL = os.environ.get("LITELLM_URL", "http://litellm:4000/v1/chat/completions")' >> /app/proxy_transform.py && \
    echo 'def extract_tool_call_from_text(text):' >> /app/proxy_transform.py && \
    echo '    if not text or not isinstance(text, str):' >> /app/proxy_transform.py && \
    echo '        return None' >> /app/proxy_transform.py && \
    echo '    json_pattern = r'"'"'\{[^{}]*"name"\s*:\s*"[^"]+"\s*,\s*"arguments"\s*:\s*\{[^{}]*\}[^{}]*\}'"'"'' >> /app/proxy_transform.py && \
    echo '    matches = re.findall(json_pattern, text)' >> /app/proxy_transform.py && \
    echo '    for match in matches:' >> /app/proxy_transform.py && \
    echo '        try:' >> /app/proxy_transform.py && \
    echo '            parsed = json.loads(match)' >> /app/proxy_transform.py && \
    echo '            if "name" in parsed and "arguments" in parsed:' >> /app/proxy_transform.py && \
    echo '                name = parsed.get("name") or parsed.get("function_name")' >> /app/proxy_transform.py && \
    echo '                if name:' >> /app/proxy_transform.py && \
    echo '                    return {"name": name, "arguments": json.dumps(parsed.get("arguments", {}))}' >> /app/proxy_transform.py && \
    echo '        except:' >> /app/proxy_transform.py && \
    echo '            continue' >> /app/proxy_transform.py && \
    echo '    func_pattern = r'"'"'\{[^{}]*"function_name"\s*:\s*"[^"]+"\s*,\s*"arguments"\s*:\s*\{[^{}]*\}[^{}]*\}'"'"'' >> /app/proxy_transform.py && \
    echo '    matches = re.findall(func_pattern, text)' >> /app/proxy_transform.py && \
    echo '    for match in matches:' >> /app/proxy_transform.py && \
    echo '        try:' >> /app/proxy_transform.py && \
    echo '            parsed = json.loads(match)' >> /app/proxy_transform.py && \
    echo '            if "function_name" in parsed and "arguments" in parsed:' >> /app/proxy_transform.py && \
    echo '                return {"name": parsed["function_name"], "arguments": json.dumps(parsed["arguments"])}' >> /app/proxy_transform.py && \
    echo '        except:' >> /app/proxy_transform.py && \
    echo '            continue' >> /app/proxy_transform.py && \
    echo '    return None' >> /app/proxy_transform.py && \
    echo '@app.route("/v1/chat/completions", methods=["POST", "OPTIONS"])' >> /app/proxy_transform.py && \
    echo 'def proxy():' >> /app/proxy_transform.py && \
    echo '    if request.method == "OPTIONS":' >> /app/proxy_transform.py && \
    echo '        response = jsonify({"status": "ok"})' >> /app/proxy_transform.py && \
    echo '        response.headers.add("Access-Control-Allow-Origin", "*")' >> /app/proxy_transform.py && \
    echo '        response.headers.add("Access-Control-Allow-Headers", "Content-Type,Authorization")' >> /app/proxy_transform.py && \
    echo '        response.headers.add("Access-Control-Allow-Methods", "POST,OPTIONS")' >> /app/proxy_transform.py && \
    echo '        return response' >> /app/proxy_transform.py && \
    echo '    try:' >> /app/proxy_transform.py && \
    echo '        if not request.is_json:' >> /app/proxy_transform.py && \
    echo '            return jsonify({"error": "Content-Type must be application/json"}), 415' >> /app/proxy_transform.py && \
    echo '        data = request.json' >> /app/proxy_transform.py && \
    echo '        if not data:' >> /app/proxy_transform.py && \
    echo '            return jsonify({"error": "Empty JSON data"}), 400' >> /app/proxy_transform.py && \
    echo '        logger.info(f"Request recibida")' >> /app/proxy_transform.py && \
    echo '        if "model" not in data:' >> /app/proxy_transform.py && \
    echo '            data["model"] = "localIA:latest"' >> /app/proxy_transform.py && \
    echo '        response = requests.post(LITELLM_URL, json=data, headers={"Content-Type": "application/json"}, timeout=120)' >> /app/proxy_transform.py && \
    echo '        response.raise_for_status()' >> /app/proxy_transform.py && \
    echo '        result = response.json()' >> /app/proxy_transform.py && \
    echo '        if "choices" in result and len(result["choices"]) > 0:' >> /app/proxy_transform.py && \
    echo '            message = result["choices"][0].get("message", {})' >> /app/proxy_transform.py && \
    echo '            content = message.get("content", "")' >> /app/proxy_transform.py && \
    echo '            if content and isinstance(content, str):' >> /app/proxy_transform.py && \
    echo '                tool_call = extract_tool_call_from_text(content)' >> /app/proxy_transform.py && \
    echo '                if tool_call:' >> /app/proxy_transform.py && \
    echo '                    logger.info("Tool call detectado: " + tool_call["name"])' >> /app/proxy_transform.py && \
    echo '                    result["choices"][0]["message"]["content"] = None' >> /app/proxy_transform.py && \
    echo '                    result["choices"][0]["message"]["tool_calls"] = [{' >> /app/proxy_transform.py && \
    echo '                        "id": "call_" + uuid.uuid4().hex[:8],' >> /app/proxy_transform.py && \
    echo '                        "type": "function",' >> /app/proxy_transform.py && \
    echo '                        "function": {' >> /app/proxy_transform.py && \
    echo '                            "name": tool_call["name"],' >> /app/proxy_transform.py && \
    echo '                            "arguments": tool_call["arguments"]' >> /app/proxy_transform.py && \
    echo '                        }' >> /app/proxy_transform.py && \
    echo '                    }]' >> /app/proxy_transform.py && \
    echo '                    result["choices"][0]["finish_reason"] = "tool_calls"' >> /app/proxy_transform.py && \
    echo '        json_response = jsonify(result)' >> /app/proxy_transform.py && \
    echo '        json_response.headers.add("Access-Control-Allow-Origin", "*")' >> /app/proxy_transform.py && \
    echo '        return json_response' >> /app/proxy_transform.py && \
    echo '    except json.JSONDecodeError as e:' >> /app/proxy_transform.py && \
    echo '        logger.error(f"Error decodificando JSON: {str(e)}")' >> /app/proxy_transform.py && \
    echo '        return jsonify({"error": f"Invalid JSON: {str(e)}"}), 400' >> /app/proxy_transform.py && \
    echo '    except Exception as e:' >> /app/proxy_transform.py && \
    echo '        logger.error(f"Error: {str(e)}")' >> /app/proxy_transform.py && \
    echo '        return jsonify({"error": str(e)}), 500' >> /app/proxy_transform.py && \
    echo '@app.route("/health", methods=["GET"])' >> /app/proxy_transform.py && \
    echo 'def health():' >> /app/proxy_transform.py && \
    echo '    response = jsonify({"status": "ok"})' >> /app/proxy_transform.py && \
    echo '    response.headers.add("Access-Control-Allow-Origin", "*")' >> /app/proxy_transform.py && \
    echo '    return response' >> /app/proxy_transform.py && \
    echo 'if __name__ == "__main__":' >> /app/proxy_transform.py && \
    echo '    app.run(host="0.0.0.0", port=5000, debug=False)' >> /app/proxy_transform.py

EXPOSE 5000

CMD ["python", "/app/proxy_transform.py"]
